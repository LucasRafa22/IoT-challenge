    {
        "id": "0ae4e392a620d882",
        "type": "function",
        "z": "ea9d833410528300",
        "name": "temperatura",
        "func": "const temp = Number(msg.payload);\n\nif (isNaN(temp) || temp < 30 || temp > 45) {\n    node.warn(\"Leitura ignorada: Valor fora da escala biológica.\");\n    return null;\n}\n\nlet descricao = \"\";\nlet status = \"\";\n\nif (temp >= 39.5) {\n    descricao = \"Febre alta detectada\";\n    status = \"critico\";\n} \nelse if (temp >= 39.1) {\n    descricao = \"Temperatura levemente elevada\";\n    status = \"alerta\";\n} \nelse if (temp >= 37.5) {\n    descricao = \"Temperatura normal\";\n    status = \"ok\";\n} \nelse if (temp >= 36.0) {\n    descricao = \"Temperatura baixa (hipotermia leve)\";\n    status = \"alerta\";\n} \nelse {\n    descricao = \"Hipotermia grave\";\n    status = \"critico\";\n}\n\n\nlet msgSql = {\n    topic: `INSERT INTO pet_saude (descricao, status) VALUES ('${descricao} - ${temp}°C', '${status}')`\n};\n\n\nlet msgDash = {\n    payload: descricao,\n    statusCode: status,\n    value: temp \n};\n\nreturn [msgSql, msgDash];",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 410,
        "y": 160,
        "wires": [
            [
                "a6a47ed5023dc746"
            ],
            [
                "c5e46c3ac4483f4d"
            ]
        ]
    },
    {
        "id": "87c6820adf2cf68d",
        "type": "function",
        "z": "ea9d833410528300",
        "name": "atividade",
        "func": "const atividade = Number(msg.payload);\n\nif (isNaN(atividade) || atividade < 0 || atividade > 500) {\n    node.warn(`Atividade ignorada: ${atividade} está fora da escala (0-500).`);\n    return null;\n}\n\nlet descricao = \"\";\nlet status = \"\";\n\nif (atividade <= 10) {\n    descricao = \"Em repouso\";\n    status = \"ok\";\n} \nelse if (atividade <= 50) {\n    descricao = \"Movimento leve\";\n    status = \"ok\";\n} \nelse if (atividade <= 150) {\n    descricao = \"Atividade moderada\";\n    status = \"alerta\";\n} \nelse {\n    descricao = \"Atividade excessiva\";\n    status = \"critico\";\n}\n\n\nlet msgSql = {\n    topic: `INSERT INTO pet_saude (descricao, status) VALUES ('${descricao} - ${atividade}°C', '${status}')`\n};\n\n\nlet msgDash = {\n    payload: descricao, \n    descricao: descricao,\n    status: status\n\n};\n\nreturn [msgSql, msgDash];\n",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 400,
        "y": 480,
        "wires": [
