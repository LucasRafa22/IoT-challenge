    {
        "id": "facaae3ea09f064e",
        "type": "function",
        "z": "ea9d833410528300",
        "name": "tabela de historico",
        "func": "msg.payload = msg.payload.map(row => {\n\n    let cor = \"\";\n\n    if (row.status === \"critico\") cor = \"🔴\";\n    else if (row.status === \"alerta\") cor = \"🟡\";\n    else cor = \"🟢\";\n\n    return {\n        data: row.data_registro,\n        descricao: row.descricao,\n        status: cor + \" \" + row.status\n    };\n});\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 710,
        "y": 660,
        "wires": [
