                "71b49e9283660b21"
            ]
        ]
    },
    {
        "id": "ac43eda93067fb5b",
        "type": "function",
        "z": "ea9d833410528300",
        "name": "mysql tabela",
        "func": "msg.topic = `\nSELECT \n  data_registro,\n  descricao,\n  status\nFROM pet_saude\nORDER BY data_registro DESC\nLIMIT 20\n`;\n\nreturn msg;",
